# Replace trains.your-domain.com with your actual subdomain.
# Caddy handles TLS via Let's Encrypt automatically.
# Password auth is handled by the Flask app (DASHBOARD_PASSWORD_HASH in .env).

trains.your-domain.com {
    reverse_proxy localhost:8000

    log {
        output file /var/log/caddy/late-train.log
        level ERROR
    }
}
