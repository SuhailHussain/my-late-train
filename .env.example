# Copy this to .env and fill in your credentials.
# Never commit .env to version control.

# Realtime Trains API — register at https://api-portal.rtt.io
# Copy the long-lived refresh token from your account dashboard.
RTT_REFRESH_TOKEN=your_refresh_token_here

# National Rail HSP API — register at https://raildata.org.uk
# Go to Profile → API Subscriptions → enable "HSP Historical".
# Your API key appears under "My Subscriptions".
HSP_API_KEY=your_hsp_api_key_here
