# Copy this to .env and fill in your credentials.
# Never commit .env to version control.

# Realtime Trains API (register at https://api-portal.rtt.io)
# Use the long-lived refresh token shown in your account dashboard.
RTT_REFRESH_TOKEN=your_refresh_token_here

# National Rail HSP API (register at https://raildata.org.uk)
# Enable "HSP" subscription in your profile after registration.
HSP_USERNAME=your_nre_email@example.com
HSP_PASSWORD=your_nre_password
