# Copy this to .env and fill in your credentials.
# Never commit .env to version control.

# Realtime Trains API — register at https://api-portal.rtt.io
# Copy the long-lived refresh token from your account dashboard.
RTT_REFRESH_TOKEN=your_refresh_token_here

# National Rail HSP API — register at https://raildata.org.uk
# Go to Profile → API Subscriptions → enable "HSP Historical".
# Your API key appears under "My Subscriptions".
HSP_API_KEY=your_hsp_api_key_here

# Dashboard password protection (optional but recommended for public deployments).
# Generate the hash with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"
# Then paste the output here. Leave blank to disable auth.
DASHBOARD_PASSWORD_HASH=

# Flask session secret — set to a long random string in production.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
